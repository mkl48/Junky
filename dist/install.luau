	NetworkController = true,
	NetworkManager = true,
}

local function classify(name: string): string?
	if name:match("Controller$") then
		return "Controller"
	elseif name:match("Manager$") then
		return "Manager"
	elseif name:match("Service$") then
		return "Service"
	end
	return nil
end

